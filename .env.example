# Data source per platform: "stub" (fixtures) or "real" (live). Default is stub.
# Whatnot real = free anonymous GraphQL (see lib/whatnot/real.ts). For local MVP,
# copy to .env.local with WHATNOT_SOURCE=real — dashboard hits live data with a
# ~3-minute in-process cache (lib/whatnot/cache.ts). No Postgres required.
WHATNOT_SOURCE=stub

# TikTok real requires a paid scraper provider (TikTok has no free anonymous API).
# Leave unset to serve TikTok sample data. Set TIKTOK_SOURCE=real + a provider token
# to go live (RealTikTok targets an Apify actor by default; see lib/tiktok/real.ts).
TIKTOK_SOURCE=stub
TIKTOK_PROVIDER_TOKEN=
TIKTOK_PROVIDER_ACTOR=

# --- Phase 2: turn on history (user-run, ~half day) ---
# 1. Provision Postgres at https://neon.tech (or Vercel Postgres integration)
# 2. Set DATABASE_URL below + WHATNOT_SOURCE=real + CRON_SECRET (random string)
# 3. Run: npm run db:push
# 4. Deploy to Vercel (Pro recommended for hourly cron — Hobby is daily-only)
# 5. Verify: GET /api/cron/collect with Authorization: Bearer <CRON_SECRET>
# 6. Monitor: GET /api/cron/status — expect daysAvailable to reach 7 before trend UI activates
# 7. Wait ~7 days of hourly snapshots before history-backed trends are meaningful

# Serverless Postgres (Neon / Vercel Postgres) — required by the collector only.
# The dashboard runs fine without it. Get one free at https://neon.tech or via
# the Vercel Postgres integration, then run `npm run db:push`.
DATABASE_URL=

# Shared secret for the Vercel Cron collector. When set, /api/cron/collect
# requires `Authorization: Bearer <CRON_SECRET>` (Vercel Cron sends this
# automatically). Leave empty for local testing.
CRON_SECRET=
